// JobPilot database schema.
// Models arrive incrementally:
//   Step 1 — Job
//   Step 2 — Resume, JobEnrichment, FitScore, Application
// See SPEC.md §4 for the data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
