// JobPilot database schema.
// Models arrive incrementally:
//   Step 1 — Job
//   Step 2 — Resume, JobEnrichment, FitScore, Application
// See SPEC.md §4 for the data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A job posting scraped from a company ATS feed (Greenhouse / Lever / Ashby).
model Job {
  id          String    @id @default(cuid())
  source      String // "greenhouse" | "lever" | "ashby"
  sourceJobId String // the ATS's own id for this posting
  title       String
  company     String
  location    String
  url         String
  rawJd       String    @db.Text // full job-description text (needed for AI in Step 2)
  postedAt    DateTime?
  ingestedAt  DateTime  @default(now())

  enrichment JobEnrichment?
  fitScore   FitScore?

  @@unique([source, sourceJobId])
  @@index([ingestedAt])
}

/// Shubham's résumé — the target every job is scored against. `active` lets him
/// A/B different résumé versions.
model Resume {
  id        String   @id @default(cuid())
  content   String   @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Structured fields an LLM (Haiku) extracts from a job's raw JD text.
model JobEnrichment {
  id               String   @id @default(cuid())
  jobId            String   @unique
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seniority        String?
  minYears         Int?
  stack            String[]
  remotePolicy     String?
  responsibilities String[]
  model            String
  createdAt        DateTime @default(now())
}

/// An LLM (Sonnet) fit score of a job against the active résumé.
model FitScore {
  id            String   @id @default(cuid())
  jobId         String   @unique
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  score         Int // 0–100
  matchedSkills String[]
  gaps          String[]
  rationale     String   @db.Text
  model         String
  createdAt     DateTime @default(now())
}
